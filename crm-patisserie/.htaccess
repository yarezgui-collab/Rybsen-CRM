# Bloquer l'accès direct aux fichiers de rate-limit et de configuration
<FilesMatch "^(config\.php|\.rl[a-f0-9]+\.json)$">
    Order Allow,Deny
    Deny from all
</FilesMatch>

# Forcer l'encodage UTF-8
AddDefaultCharset UTF-8

# Interdire la navigation dans les dossiers
Options -Indexes

# Page d'entrée par défaut
DirectoryIndex index.html index.php

# Anti-cache : garantit que chaque déploiement est pris en compte immédiatement
# (évite qu'un navigateur/CDN serve un ancien index.html — cause de bugs "déjà corrigés"
#  qui semblent persister côté utilisateur).
<IfModule mod_headers.c>
    # La page principale : toujours revalider auprès du serveur avant réutilisation
    <FilesMatch "\.html$">
        Header set Cache-Control "no-cache, must-revalidate"
    </FilesMatch>
    # L'API : jamais mise en cache (réponses toujours fraîches)
    <FilesMatch "\.php$">
        Header set Cache-Control "no-store"
    </FilesMatch>
</IfModule>

# Cache serveur LiteSpeed (Hostinger) : désactivé pour ce dossier, sinon une
# ancienne version de index.html peut continuer à être servie APRÈS déploiement,
# malgré les en-têtes ci-dessus. C'est la cause typique d'un correctif « invisible ».
<IfModule LiteSpeed>
    CacheDisable public /
    RewriteEngine On
    RewriteRule .* - [E=Cache-Control:no-cache]
</IfModule>
