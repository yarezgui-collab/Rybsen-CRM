# RYBSEN CRM — Durcissement Apache (Hostinger)

# Bloquer l'accès direct aux fichiers sensibles
<FilesMatch "^(config\.php|config\.example\.php|.*\.sql|\.gitignore|README\.md)$">
  Require all denied
</FilesMatch>

# Pas de listing de répertoires
Options -Indexes

# Headers de sécurité (complément de includes/security.php)
<IfModule mod_headers.c>
  Header always set X-Content-Type-Options "nosniff"
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

# Forcer HTTPS
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteCond %{HTTPS} !=on
  RewriteCond %{HTTP:X-Forwarded-Proto} !https
  RewriteRule ^(.*)$ https://%{HTTP_HOST}/$1 [R=301,L]
</IfModule>
